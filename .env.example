# Copy to .env and fill in values — never commit .env

# LLM (OpenRouter — free tier)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Storage
DUCKDB_PATH=./data/pelican.duckdb
DATA_DIR=./data/cache

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Backtest defaults
BACKTEST_START=2014-01-01
BACKTEST_END=2024-01-01
# Universe is always S&P 500 (no config needed)

# arXiv search: no API key required
# Rate limit: 1 request per 3 seconds (enforced in pelican/agents/tools/search.py)
ARXIV_RATE_LIMIT_SECONDS=3
